  "main_section_html": "<div class=\"error-wrapper\">\r\n  <div class=\"error-card\">\r\n    <div id=\"error-icon\" class=\"error-icon\">⚠️</div>\r\n\r\n    <h1 id=\"error-title\" class=\"error-title\">Error</h1>\r\n\r\n    <p id=\"error-message\" class=\"error-message\">\r\n      Something went wrong.\r\n    </p>\r\n\r\n    <button id=\"retry-btn\" class=\"retry-btn\">\r\n      🔄 Retry Login\r\n    </button>\r\n  </div>\r\n</div>\r\n\r\n<style>\r\n\r\n  body {\r\n    margin: 0;\r\n    background: linear-gradient(135deg, #dbeafe, #f3f4f6);\r\n    font-family: Inter, sans-serif;\r\n  }\r\n\r\n  .error-wrapper {\r\n    height: 100vh;\r\n    display: flex;\r\n    justify-content: center;\r\n    align-items: center;\r\n    padding: 20px;\r\n  }\r\n\r\n  .error-card {\r\n    width: 420px;\r\n    padding: 32px;\r\n    background: rgba(255, 255, 255, 0.75);\r\n    backdrop-filter: blur(18px);\r\n    border-radius: 20px;\r\n    box-shadow: 0 12px 34px rgba(0, 0, 0, 0.15);\r\n    text-align: center;\r\n    animation: fadeIn 0.5s ease;\r\n  }\r\n\r\n  @keyframes fadeIn {\r\n    from { opacity: 0; transform: translateY(15px); }\r\n    to   { opacity: 1; transform: translateY(0); }\r\n  }\r\n\r\n  .error-icon {\r\n    font-size: 48px;\r\n    margin-bottom: 10px;\r\n  }\r\n\r\n  .error-title {\r\n    font-size: 28px;\r\n    margin: 0;\r\n    margin-bottom: 10px;\r\n    color: #1f2937;\r\n  }\r\n\r\n  .error-message {\r\n    font-size: 16px;\r\n    color: #4b5563;\r\n    margin-bottom: 24px;\r\n    line-height: 1.6;\r\n  }\r\n\r\n  .retry-btn {\r\n    background: #2563eb;\r\n    border: none;\r\n    padding: 14px 26px;\r\n    color: white;\r\n    border-radius: 10px;\r\n    cursor: pointer;\r\n    font-size: 16px;\r\n    font-weight: 600;\r\n    transition: 0.25s;\r\n  }\r\n\r\n  .retry-btn:hover {\r\n    background: #1d4ed8;\r\n    transform: scale(1.03);\r\n  }\r\n\r\n</style>\r\n\r\n<script>\r\n  const params = new URLSearchParams(window.location.search);\r\n  const reason = params.get(\"reason\");\r\n  const value = params.get(\"value\");\r\n  const failed = params.get(\"failed\");\r\n\r\n  const title = document.getElementById(\"error-title\");\r\n  const message = document.getElementById(\"error-message\");\r\n  const icon = document.getElementById(\"error-icon\");\r\n\r\n  if (reason === \"inactive\") {\r\n    title.textContent = \"Invite Not Active\";\r\n    message.textContent =\r\n      \"This invitation is no longer active. Please contact support or try again later.\";\r\n    icon.textContent = \"🚫\";\r\n  }\r\n\r\n  if (reason === \"limit\") {\r\n    title.textContent = \"Observer Limit Reached\";\r\n    message.innerHTML =\r\n      `The maximum number of observers (<strong>${value}</strong>) is already in use There are ${failed} waiting user to join and you are one of them.<br>Please try again shortly.`;\r\n    icon.textContent = \"⏳\";\r\n  }\r\n\r\n  if (!reason) {\r\n    title.textContent = \"Unexpected Error\";\r\n    message.textContent = \"Something unexpected happened. Please try again later.\";\r\n    icon.textContent = \"⚠️\";\r\n  }\r\n\r\n  // Retry button logic\r\ndocument.getElementById(\"retry-btn\").onclick = () => {\r\n  const apiUrl = `${window.location.origin}/api/method/login_aircraft_observing_invite`;\r\n  window.location.href = apiUrl;\r\n};\r\n</script>\r\n",
